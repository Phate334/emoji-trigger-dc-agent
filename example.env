# Discord Configuration
# Required: Your Discord bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Optional: Path to the agent manifest configuration file
# Default: agents/agents.yaml
# EMOJI_AGENT_MANIFEST=agents/agents.yaml

# Claude Code SDK Configuration
# Choose at least one authentication method:
# 1. ANTHROPIC_API_KEY
#    Official Anthropic API / Agent SDK standard setting.
#    Claude Code sends this as the X-Api-Key header.
#    Use a real key when talking directly to Anthropic.
# 2. ANTHROPIC_AUTH_TOKEN
#    Claude Code alternative setting for the Authorization: Bearer header.
#    Useful for proxies / gateways that expect bearer auth.
# If you set ANTHROPIC_BASE_URL to a proxy or local endpoint, either one may be enough
# depending on what that endpoint expects.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_AUTH_TOKEN=your-bearer-token-here

# Optional: Custom base URL for Claude API (for proxy or alternative endpoints)
# Default: https://api.anthropic.com (official Anthropic API)
# For the bundled docker-compose llama.cpp service, use: http://llm:8080
# Example bearer-auth gateway setup:
# ANTHROPIC_AUTH_TOKEN=your-gateway-token
# ANTHROPIC_BASE_URL=https://your-gateway.example.com
# ANTHROPIC_BASE_URL=http://localhost:8080

# Optional: Default model id for Claude Code SDK (route-level model still takes precedence)
# Example: claude-sonnet-4-5
# CLAUDE_MODEL=claude-sonnet-4-5

# Optional: Maximum Claude turns per trigger
# Default: 4
# CLAUDE_MAX_TURNS=4

# Storage Configuration
# Optional: Root directory where triggered agents write durable outputs
# Default: /app/outputs
# AGENT_OUTPUTS_ROOT=/app/outputs

# Optional: SQLite database path for the durable trigger queue
# Default: <AGENT_OUTPUTS_ROOT>/trigger_queue.sqlite3
# If unset, the app derives it automatically from AGENT_OUTPUTS_ROOT.
# TRIGGER_QUEUE_DB_PATH=/app/outputs/trigger_queue.sqlite3

# Trigger Queue Configuration
# Optional: Number of queue worker tasks to run in parallel
# Default: 1
# TRIGGER_QUEUE_WORKER_CONCURRENCY=1

# Optional: Poll interval for the background queue worker in seconds
# Default: 1
# TRIGGER_QUEUE_POLL_INTERVAL_SECONDS=1

# Optional: Retry count after the first execution attempt fails
# Default: 3
# TRIGGER_QUEUE_RETRY_COUNT=3

# Optional: Delay between queue retries in seconds
# Default: 30
# TRIGGER_QUEUE_RETRY_DELAY_SECONDS=30

# Optional: Processing lease timeout in seconds before a stuck claim is recovered
# Default: 900
# TRIGGER_QUEUE_CLAIM_TIMEOUT_SECONDS=900

# Logging Configuration
# Optional: Application log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
# LOG_LEVEL=INFO

# Optional: Discord.py library log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Separate from LOG_LEVEL to control discord.py verbosity independently
# Default: Same as LOG_LEVEL
# DISCORD_LOG_LEVEL=INFO
