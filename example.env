# Discord Configuration
# Required: Your Discord bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Optional: Path to the agent manifest configuration file
# Default: claude/agents/agents.yaml
EMOJI_AGENT_MANIFEST=claude/agents/agents.yaml

# Logging Configuration
# Optional: Application log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# Optional: Discord.py library log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Separate from LOG_LEVEL to control discord.py verbosity independently
# Default: Same as LOG_LEVEL
DISCORD_LOG_LEVEL=INFO

# Claude Code SDK Configuration
# Required: Your Anthropic API key from Claude Console (https://platform.claude.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Default model id for Claude Code SDK (route-level model still takes precedence)
# Example: claude-sonnet-4-5
# CLAUDE_MODEL=claude-sonnet-4-5

# Optional: Custom base URL for Claude API (for proxy or alternative endpoints)
# Default: https://api.anthropic.com (official Anthropic API)
# ANTHROPIC_BASE_URL=http://localhost:8080
